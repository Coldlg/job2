// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Lottery {
  id              Int      @id @default(autoincrement())
  title           String
  description     String
  price           Int
  ticketsSold     Int
  maximumTickets  Int
  drawDate        DateTime
  images          String[] // Array of image URLs
  accountNumber   String?
  accountName     String?
  bankName        String?
  isHidden        Boolean  @default(false)
  tickets         Ticket[]
}

model Car {
  id             Int      @id @default(autoincrement())
  make           String
  model          String
  year           Int
  price          Int
  mileageKm      Int
  color          String
  engine         String
  transmission   String
  rating         Float
  description    String
  images         String[]
}

model Ticket {
  id             Int       @id @default(autoincrement())
  lottery_id     Int
  ticket_number  Int
  phone_number   String
  amount_paid    Decimal   @db.Decimal(10, 2)
  is_winner      Boolean   @default(false)
  created_at     DateTime  @default(now())
  import_batch_id Int?

  lottery        Lottery @relation(fields: [lottery_id], references: [id], onDelete: Cascade)
  importLog      ImportLog? @relation(fields: [import_batch_id], references: [id], onDelete: Cascade)

  @@unique([lottery_id, ticket_number])
  @@index([lottery_id])
}

model ImportLog {
  id           Int      @id @default(autoincrement())
  lottery_id   Int
  ticket_count Int
  start_ticket Int
  end_ticket   Int
  imported_at  DateTime @default(now())
  tickets      Ticket[]

  @@index([lottery_id])
  @@index([imported_at])
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  action      String   // IMPORT_TICKETS, EXPORT_TICKETS, CREATE_TICKET, UPDATE_TICKET, DELETE_TICKET, LOGIN, LOGOUT, CREATE_LOTTERY, UPDATE_LOTTERY, DELETE_LOTTERY
  entity      String?  // Ticket, Lottery, Car, User
  entity_id   Int?     // ID of the affected entity
  lottery_id  Int?     // Related lottery ID (if applicable)
  user_id     Int?     // User who performed the action (if authenticated)
  user_email  String?  // Email of the user
  metadata    Json?    // Additional data (e.g., old/new values, count, file name)
  ip_address  String?  // IP address of the user
  user_agent  String?  // Browser/device info
  created_at  DateTime @default(now())

  @@index([action])
  @@index([entity])
  @@index([entity_id])
  @@index([lottery_id])
  @@index([created_at])
}
